// --- RDZEŃ SYSTEMU ---

Table Uzytkownik {
  Id_uzytkownika int [pk, increment]
  Imie varchar(100)
  Nazwisko varchar(100)
  Email varchar(150)
  Telefon varchar(20) // Zmienione z int na varchar
  Hasło varchar(255)
  Rola varchar(50)
}

Table Zwierze {
  Id_zwierzecia int [pk, increment]
  Imie varchar(100)
  Gatunek varchar(50)
  Rasa varchar(100)
  Wiek int
  Płeć varchar(10)
  Status varchar(50)
  data_przyjecia date
  opis text
  zdjecie varchar(255)
  // Id_boksu usunięte - teraz jest w HistoriaMiejsca
}

Table Pracownik {
  Id_pracownika int [pk, increment]
  Imie varchar(100)
  Nazwisko varchar(100)
  Stanowisko varchar(100)
  Telefon varchar(20)
  email varchar(150)
}

// --- PIVOTY I HISTORIA (ZMIANY) ---

// Spacer może mieć wielu ludzi i wiele zwierząt
Table Spacer {
  Id_spaceru int [pk, increment]
  data_spaceru date
  godzina time
  status varchar(50)
}

Table Spacer_Uzytkownik {
  Id_spaceru int [ref: > Spacer.Id_spaceru]
  Id_uzytkownika int [ref: > Uzytkownik.Id_uzytkownika]
}

Table Spacer_Zwierze {
  Id_spaceru int [ref: > Spacer.Id_spaceru]
  Id_zwierzecia int [ref: > Zwierze.Id_zwierzecia]
}

// Adopcja - wielu ludzi może adoptować wiele zwierząt na raz
Table Adopcja {
  Id_adopcji int [pk, increment]
  data_zlozenia date
  status varchar(50)
  Id_pracownika int [ref: > Pracownik.Id_pracownika]
}

Table Adopcja_Uzytkownik {
  Id_adopcji int [ref: > Adopcja.Id_adopcji]
  Id_uzytkownika int [ref: > Uzytkownik.Id_uzytkownika]
}

Table Adopcja_Zwierze {
  Id_adopcji int [ref: > Adopcja.Id_adopcji]
  Id_zwierzecia int [ref: > Zwierze.Id_zwierzecia]
}

// Historia przebywania w boksach
Table HistoriaMiejsca {
  Id_historii int [pk, increment]
  Id_zwierzecia int [ref: > Zwierze.Id_zwierzecia]
  Id_boksu int [ref: > Boks.Id_boksu]
  Id_pracownika int [ref: > Pracownik.Id_pracownika] // kto przeniósł
  data_od datetime
  data_do datetime
}

Table Boks {
  Id_boksu int [pk, increment]
  numer int
  typ varchar(50)
  pojemnosc int
}

// Wolontariat z historią zmian statusu
Table Wolontariusz_Historia {
  Id_wpisu int [pk, increment]
  Id_uzytkownika int [ref: > Uzytkownik.Id_uzytkownika]
  data_zmiany date
  status varchar(50) // np. aktywny, zawieszony, były
  notatka text
}

// --- POZOSTAŁE FUNKCJE ---

Table TerminarzMedyczny {
  Id_zdarzenia int [pk, increment]
  Id_zwierzecia int [ref: > Zwierze.Id_zwierzecia]
  typ_zabiegu varchar(100) // np. szczepienie, odrobaczanie
  data_planowana date
  data_wykonania date
  koszt decimal
}

Table Darowizna {
  Id_darowizny int [pk, increment]
  Id_uzytkownika int [ref: > Uzytkownik.Id_uzytkownika, null] // opcjonalne
  Id_zwierzecia int [ref: > Zwierze.Id_zwierzecia, null] // celowa na zwierzaka
  Id_pracownika int [ref: > Pracownik.Id_pracownika] // kto przyjął
  kwota decimal
  data datetime
}

Table FormularzKontaktowy {
  Id_wiadomosci int [pk, increment]
  Imie varchar(100)
  email varchar(50)
  temat varchar(100)
  tresc text
  data_wyslania datetime
  status varchar(50)
  Id_pracownik_przyjmujacy int [ref: > Pracownik.Id_pracownika]
  Id_pracownik_odpowiadajacy int [ref: > Pracownik.Id_pracownika]
}

#Spacery i Adopcje: Teraz to "wydarzenia" łączone przez tabele pośredniczące. Pozwala to np. na sytuację, gdzie dwójka wolontariuszy bierze trzy psy na jeden wspólny spacer.
• Logistyka (Boksy): Usunelam Id_boksu bezpośrednio ze zwierzęcia. Teraz mamy tabelę HistoriaMiejsca. Dzięki temu wiesz dokładnie, gdzie pies był miesiąc temu i który pracownik go tam przeniósł.
• Wolontariat: Zamiast jednej tabeli Wolontariusz, masz Wolontariusz_Historia. Jeśli ktoś zrezygnuje, a po roku wróci — będziesz mieć oba te wpisy w historii.
• Zdrowie: Dodalam tabelę TerminarzMedyczny. Możesz tam wpisać "Szczepienie przeciw wściekliźnie" z datą za 100 dni i śledzić, czy zostało wykonane.
• Darowizny i Kontakt: Zgodnie z prośbą, darowizny są teraz powiązane z darczyńcą, konkretnym pupilem i pracownikiem "kasjerem". Wiadomości mają teraz przypisanych ludzi odpowiedzialnych za obsługę
